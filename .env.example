# ===== AlphaLens environment variables =====
# Copy to .env.local and fill in real values. Never commit .env.local.

# Anthropic (Claude)
ANTHROPIC_API_KEY=
# Optional model override. Spec asked for claude-sonnet-4-20250514; the app
# defaults to an available pinned Sonnet if this is unset.
ANTHROPIC_MODEL=

# Tavily web search
TAVILY_API_KEY=

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/research
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/research

# Supabase (database). URL must be a full https://xxx.supabase.co URL.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (payments) — added later in the project
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_ID=
